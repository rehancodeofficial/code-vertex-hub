NODE_ENV=development
PORT=4000

# Database Connection Strings
DATABASE_URL=postgresql://user:password@host:port/dbname?schema=public
DIRECT_URL=postgresql://user:password@host:port/dbname?schema=public

# Security Credentials
JWT_ACCESS_SECRET=your-32-character-access-secret-key-goes-here
JWT_REFRESH_SECRET=your-32-character-refresh-secret-key-goes-here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# CORS Allowed Origin
CORS_ORIGIN=http://localhost:5173

# Supabase Configurations
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage and Defaults
UPLOAD_DIR=uploads
DEFAULT_EMPLOYEE_PASSWORD=demo1234
